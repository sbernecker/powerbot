# Copy this file to .streamlit/secrets.toml and fill in real values.
# .streamlit/secrets.toml is gitignored — never commit it.

# Your Anthropic API key. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY = "sk-ant-..."

# Password testers will enter before they can use the chatbot.
# Pick something simple but not guessable. Share it with testers separately.
APP_PASSWORD = "change-me"
